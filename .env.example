# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# PostgreSQL (Supabase) — use postgresql:// or postgresql+asyncpg://
# URL-encode special characters in password, e.g. @ → %40
DATABASE_URL=postgresql+asyncpg://postgres:your_password@db.your_project.supabase.co:5432/postgres

# Application
LOG_LEVEL=INFO
